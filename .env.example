# ===== 复制为 .env 并填入真实值；.env 已被 gitignore，密钥不入库 =====

# --- 基础设施 ---
MYSQL_HOST=localhost
MYSQL_PORT=13307
MYSQL_USER=root
MYSQL_PASSWORD=123456
REDIS_HOST=localhost
REDIS_PORT=16380
NACOS_HOST=localhost
NACOS_PORT=8950

# --- MinIO 对象存储 ---
MINIO_ENDPOINT=http://localhost:19000
MINIO_ROOT_USER=shopadmin
MINIO_ROOT_PASSWORD=shopadmin123
MINIO_BUCKET=shop-images

# --- SMTP 邮件（注册验证码；dev profile 下只打印控制台可不配） ---
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your@gmail.com
MAIL_PASSWORD=your-app-password

# --- Stripe（沙箱：sk_test_ 开头；上线换 sk_live_） ---
STRIPE_ENABLED=false
STRIPE_API_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# --- PayPal（沙箱 client；上线换 live） ---
PAYPAL_ENABLED=false
PAYPAL_CLIENT_ID=xxx
PAYPAL_CLIENT_SECRET=xxx
PAYPAL_MODE=sandbox

# --- 安全 ---
# 身份证号 AES 加密密钥（16/24/32 字节）
IDENTITY_AES_KEY=change-me-16byte
